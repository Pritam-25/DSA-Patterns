flowchart TB
    A["1: f(0, [ ], sum=0)"] -- add 3 --> B["2: f(1, [3], sum=3)"]
    B -- add 1 --> C["3: f(2, [3,1], sum=4)"]
    A -- not take 3 --> n1["NOT EXECUTED (early stop)"]
    C -- add 2 --> D["4: f(3, [3,1,2], sum=6)"]
    D -- sum > k --> D1["PRUNE → return false"]
    C -- not take 2 --> E["5: f(3, [3,1], sum=4)"]
    E -- add 4 --> F["6: f(4, [3,1,4], sum=8)"]
    F -- sum > k --> F1["PRUNE → return false"]
    E -- not take 4 --> G["7: f(4, [3,1], sum=4)"]
    G -- "index == n" --> G1["sum != k → return false"]
    B -- not take 1 --> H["8: f(2, [3], sum=3)"]
    H -- add 2 --> I["9: f(3, [3,2], sum=5)"]
    I -- add 4 --> J["10: f(4, [3,2,4], sum=9)"]
    J -- sum > k --> J1["PRUNE → return false"]
    I -- not take 4 --> K["11: f(4, [3,2], sum=5)"]
    K -- "index == n" --> K1(["✔ PRINT [3,2] → return true"])
    K1 --> S["STOP: no further recursion"]
    H -- not take 3 --> n2["NOT EXECUTED (early stop)"]

